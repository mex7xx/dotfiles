#!/bin/bash
{{ if eq .chezmoi.os "darwin" -}}

# Environment state hashes — changes here trigger run_onchange re-execution
# brew leaves: {{ output "brew" "leaves" | sha256sum }}
# brew casks: {{ output "brew" "list" "--cask" "-1" | sha256sum }}
# brew taps: {{ output "brew" "tap" | sha256sum }}

# Generate combined Brewfile in a temp file
brewfile=$(mktemp)
cat > "$brewfile" <<BREWEOF
{{ range .packages.universal.taps -}}
tap {{ . | quote | replace " " "\", \"" }}
{{ end -}}
{{ range .packages.universal.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.universal.casks -}}
cask {{ . | quote }}
{{ end -}}
{{ range .packages.universal.mas -}}
mas {{ .name | quote }}, id: {{ .id }}
{{ end -}}
{{ if .isWorkComputer -}}
{{ range .packages.work.taps -}}
tap {{ . | quote | replace " " "\", \"" }}
{{ end -}}
{{ range .packages.work.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.work.casks -}}
cask {{ . | quote }}
{{ end -}}
{{ range .packages.work.mas -}}
mas {{ .name | quote }}, id: {{ .id }}
{{ end -}}
{{ else -}}
{{ range .packages.private.taps -}}
tap {{ . | quote | replace " " "\", \"" }}
{{ end -}}
{{ range .packages.private.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.private.casks -}}
cask {{ . | quote }}
{{ end -}}
{{ range .packages.private.mas -}}
mas {{ .name | quote }}, id: {{ .id }}
{{ end -}}
{{ end -}}
BREWEOF

# Install packages
brew bundle --file="$brewfile"

# Warn about undeclared packages without removing them
if ! undeclared=$(brew bundle cleanup --file="$brewfile" 2>&1); then
    echo ""
    echo "WARNING: Could not check undeclared packages:"
    echo "$undeclared"
elif [[ -n "$undeclared" ]]; then
    echo ""
    echo "WARNING: Packages installed but not declared in packages.yaml:"
    echo "$undeclared"
    echo ""
    echo "Run ./audit-packages.sh to inspect drift."
    echo "Run ./cleanup-packages.sh to remove undeclared packages."
fi

rm -f "$brewfile"

{{ end -}}
